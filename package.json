{
  "name": "codex-remote",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "Standalone remote controller for the official Codex Desktop app-server.",
  "license": "MIT",
  "scripts": {
    "build": "npm run build:desktop:win",
    "build:desktop:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-desktop-win.ps1",
    "desktop:win:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File native/Start-CodexRemoteTrayDev.ps1",
    "deploy": "node scripts/deploy-all.mjs",
    "deploy:worker": "node scripts/deploy-worker.mjs",
    "deploy:web": "node scripts/deploy-web.mjs",
    "release": "node scripts/release.mjs",
    "test": "node --test",
    "remote:daemon": "node scripts/start-daemon.mjs",
    "remote:pair": "node remote/daemon/src/main.mjs pair",
    "remote:relay": "node remote/relay-node/server.mjs",
    "remote:smoke": "node remote/scripts/smoke.mjs"
  },
  "engines": {
    "node": ">=24"
  }
}
